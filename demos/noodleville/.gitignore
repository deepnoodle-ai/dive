# Compiled binary (default `go build` output is the directory name)
/noodleville

# Runtime session state (default --sessions dir is .noodleville/sessions)
/.noodleville/

# Go build/test artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Node dependencies (in case a JS toolchain is added for assets)
node_modules/

# Local environment / secrets
.env
.env.local

# Editor / IDE
.vscode/
.idea/

# macOS
.DS_Store
